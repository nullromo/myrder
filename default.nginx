server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 3202 default_server;
    listen [::]:3202 default_server;
    root /myrder/build;
    index index.html;
    server_name _;
    location / {
        try_files $uri $uri/ /index.html;
    }
}
